PORT=8787
HOST=0.0.0.0

# Public HTTPS base URL used for Twilio <Play> media URLs.
# On Render, RENDER_EXTERNAL_URL is usually available automatically, so this can stay empty.
PUBLIC_BASE_URL=

# Optional app auth. If set, requests to /api/* must send:
# Authorization: Bearer <APP_API_TOKEN>
APP_API_TOKEN=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_ID=+10000000000
# Optional JSON map for explicit <Say> voice overrides per locale.
# Example:
# TWILIO_TTS_VOICE_MAP={"fr-FR":"Polly.Mathieu","en-US":"Polly.Joanna-Generative"}
TWILIO_TTS_VOICE_MAP=
# Prefer Azure TTS + Twilio <Play> when a public base URL is available.
TWILIO_TTS_USE_PLAY=1

AZURE_REGION=eastus
AZURE_SPEECH_KEY=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=eastus
AZURE_TTS_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3
# Optional JSON map for Azure TTS voice overrides.
# Example:
# AZURE_TTS_VOICE_MAP={"uk-UA":"uk-UA-PolinaNeural","he-IL":"he-IL-HilaNeural"}
AZURE_TTS_VOICE_MAP=

TWILIO_DIRECT_TURN_WAIT_TIMEOUT_MS=10000
TWILIO_DIRECT_TURN_RECORD_MAX_LENGTH=15
TWILIO_DIRECT_TURN_RECORD_TIMEOUT=2
TWILIO_DIRECT_INITIAL_RECORD_MAX_LENGTH=30
TWILIO_DIRECT_INITIAL_RECORD_TIMEOUT=45
TWILIO_DIRECT_RECORDING_POLL_INTERVAL_MS=700
TWILIO_REMOTE_CAPTURE_RETRY_LIMIT=2
TWILIO_REMOTE_STT_MIN_RECORDING_DURATION_S=1.1

TTS_ASSET_DIR=/tmp/twilio-calls-tts
TTS_ASSET_TTL_MS=21600000
